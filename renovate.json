{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/|\\.)(Container|Docker)file$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>.*?)\\s+depName=(?<depName>.*?)(\\s+registryUrl=(?<registryUrl>.*?))?(\\s+versioning=(?<versioning>.*?))?\\s+ARG\\s+.+_VERSION=(?<currentValue>.*?)\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/|\\.).*\\.sh$/"
      ],
      "matchStrings": [
        "\\srenovate:\\s+datasource=(?<datasource>.*?)\\sdepName=(?<depName>.*?)\\n\\s*[a-zA-Z_]+=\"?(?<currentValue>.*?)\"?\\s"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^roles/.+/tasks/.+\\.yml$/"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "#\\s*renovate:(\\s*versioning=(?<versioning>.*?))?\\n\\s*image:\\s*(?<depName>.*?):(?<currentValue>.*?)\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^plays/kairos/upgrade\\.yml$/"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "#\\s*renovate:\\sdepName=(?<depName>.*?)\\n\\s+kairos_version: \"(?<currentValue>.*?)\""
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^kustomization/.+/.+/.*values\\.yml$/"
      ],
      "matchStrings": [
        "image:\\n\\s+repository:\\s+(?<depName>.*?)\\n\\s+tag:\\s+(?<currentValue>.*?)\\n",
        "'#\\srenovate:\\sdatasource=(?<datasource>.*?)\\sdepName=(?<depName>.*?)\\n\\s+tag:\\s(?<currentValue>.*?)\\n"
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^kustomization/.+/cnpg/.+\\.yml$/"
      ],
      "matchStrings": [
        "\\s+imageName:\\s+(?<depName>.+):(?<currentValue>.+?)@(?<currentDigest>sha256:[a-f0-9]{64})",
        "\\s+image:\\n\\s+reference:\\s+(?<depName>.+):(?<currentValue>.+?)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^kustomization/.+/.+/kustomization\\.yml$/",
        "/^kustomization/.+/.+/.+/kustomization\\.yml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\sdatasource=(?<datasource>.*?)\\sdepName=(?<depName>.*?)(?:\\sversioning=(?<versioning>.*?))?\\n\\s+newTag: (?<currentValue>.*?)\\n",
        "#\\s*renovate:\\sdatasource=(?<datasource>.*?)\\n\\s+- https://raw\\.githubusercontent\\.com/(?<depName>.*?)/(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)",
        "#\\s*renovate:\\sdatasource=(?<datasource>.*?)\\n\\s+- https://github\\.com/(?<depName>.*?)/raw/(?<currentValue>.*?)/",
        "#\\s*renovate:\\sdatasource=(?<datasource>.+?)(?:\\sversioning=(?<versioning>.+?))?\\n\\s+- https://github\\.com/(?<depName>.+/.+?)/?\\?ref=(?<currentValue>.+?)\\n",
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": [
        "/^kustomization/.+/.+/kustomization\\.yml$/",
        "/^kustomization/.+/.+/.+/kustomization\\.yml$/",
        "!kustomization/overlays/prod/keda/kustomization.yml"
      ],
      "matchStrings": [
        "\\s-\\shttps://raw\\.githubusercontent\\.com/(?<depName>cloudnative-pg/cloudnative-pg)/main/releases/cnpg-(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\\.yaml",
        "\\s-\\shttps://github\\.com/(?<depName>.*?/.*?)/releases/download/(?<currentValue>v?[0-9]+\\.[0-9]+\\.[0-9]+)/.+"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kedacore/keda",
      "managerFilePatterns": [
        "/^kustomization/overlays/prod/keda/kustomization\\.yml$/"
      ],
      "matchStrings": [
        "- https://github\\.com/kedacore/keda/releases/download/v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)/keda-[0-9]+\\.[0-9]+\\.[0-9]+\\.yaml"
      ],
      "autoReplaceStringTemplate": "- https://github.com/kedacore/keda/releases/download/v{{{newValue}}}/keda-{{{newValue}}}.yaml",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^plays/.+\\.yml$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\sdatasource=(?<datasource>.*?)\\sdepName=(?<depName>.*?)(?:\\sversioning=(?<versioning>.*?))?\\n\\s+[a-zA-Z_]+_version: (?<currentValue>.*?)\\n"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": [
        "/^kustomization/overlays/prod/traefik/configmap/traefik/static\\.yml$/"
      ],
      "matchStrings": [
        "moduleName:\\s+github\\.com/(?<depName>.*/.*)\\n\\s+version:\\s+(?<currentValue>.*)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "prometheus/prometheus",
      "managerFilePatterns": [
        "/^kustomization/components/.+/prometheus\\.yml$/",
        "/^kustomization/overlays/.+/.+/prometheus\\.yml$/"
      ],
      "matchStrings": [
        "version:\\s+(?<currentValue>v.*?)\\n"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "authelia/authelia",
      "managerFilePatterns": [
        "/^kustomization/overlays/prod/traefik/configmap/authelia/config\\.yml$/"
      ],
      "matchStrings": [
        "\\$schema=https://www\\.authelia\\.com/schemas/(?<currentValue>v\\d+\\.\\d+)/json-schema/configuration\\.json$"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^kustomization/overlays/prod/kairos-operator/nodeopupgrade/controlplane\\.yml$/",
        "/^kustomization/overlays/prod/kairos-operator/nodeopupgrade/workers\\.yml$/"
      ],
      "matchStrings": [
        "\\s+name:\\s+kairos-upgrade-control-plane-(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)(?:\\n.*)+\\s+image:\\s+(?<depName>.+):",
        "\\s+name:\\s+kairos-upgrade-workers-(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)(?:\\n.*)+\\s+image:\\s+(?<depName>.+):",
        "image:\\s+(?<depName>.+):(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ]
    }
  ],
  "extends": [
    "github>marinatedconcrete/config//renovate/devcontainer#renovate-config-2.5.0",
    "github>marinatedconcrete/config//renovate/marinatedconcrete#renovate-config-2.5.0",
    "github>marinatedconcrete/config//renovate/recommended#renovate-config-2.5.0"
  ],
  "packageRules": [
    {
      "description": "Automatic Minor and Patch Updates",
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": [
        "actions/checkout",
        "alloy",
        "alpine",
        "argoproj/argo-cd",
        "cert-manager/cert-manager",
        "code.forgejo.org/forgejo/runner",
        "deluan/navidrome",
        "docker.io/grafana/alloy",
        "eclipse-mosquitto",
        "forgejo",
        "ghcr.io/dancwilliams/protonmail-bridge-docker",
        "ghcr.io/paperless-ngx/paperless-ngx",
        "ghcr.io/squat/generic-device-plugin",
        "gotenberg/gotenberg",
        "grafana",
        "helm/helm",
        "jellyfin/jellyfin",
        "loki",
        "lscr.io/linuxserver/transmission",
        "mbround18/valheim",
        "prometheus-node-exporter",
        "prometheus/prometheus",
        "renovate",
        "stirling-pdf-chart",
        "twpayne/chezmoi"
      ],
      "minimumReleaseAge": "3 days",
      "schedule": [
        "after 4pm on tuesday",
        "after 4pm on thursday",
        "after 4pm on friday",
        "every weekend"
      ]
    },
    {
      "description": "Automatic Patch Updates",
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/immich-app/immich-server",
        "immich"
      ],
      "minimumReleaseAge": "1 days",
      "schedule": [
        "after 4pm every weekday",
        "every weekend"
      ]
    },
    {
      "description": "Automatic Digest Updates",
      "automerge": true,
      "automergeType": "branch",
      "matchPackageNames": [
        "busybox",
        "docker.io/bitnami/kubectl",
        "ghcr.io/blakeblackshear/frigate",
        "ghcr.io/cloudnative-pg/postgresql",
        "ghcr.io/dancwilliams/protonmail-bridge-docker",
        "ghcr.io/marinatedconcrete/devcontainer-base",
        "ghcr.io/servercontainers/samba",
        "ghcr.io/tensorchord/cloudnative-vectorchord",
        "lscr.io/linuxserver/code-server",
        "postgres"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "3 days",
      "schedule": [
        "after 4pm"
      ]
    },
    {
      "automerge": true,
      "automergeType": "branch",
      "description": "Group for all just automergeable updates",
      "groupName": "just-automerge",
      "matchPackageNames": [
        "casey/just"
      ],
      "matchUpdateTypes": [
        "digest",
        "major",
        "minor",
        "patch"
      ],
      "schedule": [
        "after 4pm on friday"
      ]
    },
    {
      "enabled": false,
      "groupName": "no-pin",
      "matchUpdateTypes": [
        "pin",
        "pinDigest"
      ],
      "matchPackageNames": [
        "forgejo",
        "ghcr.io/marinatedconcrete/kairos-fedora",
        "node-feature-discovery",
        "prometheus-adapter",
        "quay.io/fedora/fedora-bootc"
      ]
    },
    {
      "automerge": true,
      "automergeType": "branch",
      "description": "Group for all traefik automergeable updates",
      "groupName": "traefik-automerge",
      "matchPackageNames": [
        "11notes/traefik",
        "ghcr.io/authelia/authelia",
        "maxlerebourg/crowdsec-bouncer-traefik-plugin",
        "traefik/traefik",
        "traefik"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "schedule": [
        "after 4pm on tuesday",
        "after 4pm on thursday",
        "after 4pm on friday"
      ]
    },
    {
      "groupName": "kairos-control-plane",
      "matchFileNames": [
        "kustomization/overlays/prod/kairos-operator/nodeopupgrade/controlplane.yml"
      ],
      "schedule": [
        "after 4pm on tuesday",
        "after 4pm on thursday",
        "after 4pm on friday"
      ]
    },
    {
      "groupName": "kairos-workers",
      "matchFileNames": [
        "kustomization/overlays/prod/kairos-operator/nodeopupgrade/workers.yml"
      ],
      "minimumReleaseAge": "1 day",
      "schedule": [
        "after 4pm on tuesday",
        "after 4pm on thursday",
        "after 4pm on friday"
      ]
    },
    {
      "groupName": "kairos-operator",
      "matchPackageNames": [
        "kairos-io/kairos-operator",
        "quay.io/kairos/operator"
      ]
    },
    {
      "description": "Group for all Longhorn updates",
      "groupName": "longhorn",
      "matchPackageNames": [
        "longhorn/cli",
        "longhorn/longhorn"
      ]
    },
    {
      "description": "Group for all major traefik updates",
      "groupName": "traefik",
      "matchPackageNames": [
        "11notes/traefik",
        "ghcr.io/authelia/authelia",
        "maxlerebourg/crowdsec-bouncer-traefik-plugin",
        "traefik/traefik",
        "traefik"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "schedule": [
        "after 4pm on tuesday",
        "after 4pm on thursday",
        "after 4pm on friday"
      ]
    },
    {
      "description": "Group for all immich updates",
      "groupName": "immich-app",
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/immich-app/immich-server",
        "immich"
      ]
    },
    {
      "matchPackageNames": [
        "quay.io/kairos/kairos-ubuntu-22-lts"
      ],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-k3sv\\d+\\.\\d+\\.\\d+\\+k3s\\d+$"
    },
    {
      "groupName": "postgres-3d-printing",
      "matchFileNames": [
        "kustomization/overlays/prod/3d-printing/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2,
      "minimumReleaseAge": "2 days"
    },
    {
      "groupName": "postgres-atuin",
      "matchFileNames": [
        "kustomization/overlays/prod/atuin/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2,
      "minimumReleaseAge": "1 day"
    },
    {
      "groupName": "postgres-auth",
      "matchFileNames": [
        "kustomization/overlays/prod/auth/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2,
      "minimumReleaseAge": "1 day"
    },
    {
      "groupName": "postgres-crowdsec",
      "matchFileNames": [
        "kustomization/overlays/prod/crowdsec/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2
    },
    {
      "groupName": "postgres-homeassistant",
      "matchFileNames": [
        "kustomization/overlays/prod/homeassistant/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "groupName": "postgres-immich",
      "matchFileNames": [
        "kustomization/overlays/prod/immich/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "ghcr.io/tensorchord/cloudnative-vectorchord",
        "postgres"
      ],
      "minimumGroupSize": 2,
      "minimumReleaseAge": "3 days"
    },
    {
      "groupName": "postgres-monitoring",
      "matchFileNames": [
        "kustomization/overlays/prod/monitoring/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2
    },
    {
      "groupName": "postgres-paperless",
      "matchFileNames": [
        "kustomization/overlays/prod/paperless/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql",
        "postgres"
      ],
      "minimumGroupSize": 2,
      "minimumReleaseAge": "3 days"
    },
    {
      "groupName": "postgres-tandoor",
      "matchFileNames": [
        "kustomization/overlays/prod/tandoor/**"
      ],
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "automergeType": "branch",
      "groupName": "redis",
      "matchPackageNames": [
        "quay.io/opstree/redis",
        "quay.io/opstree/redis-sentinel",
        "redis-operator"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "schedule": [
        "after 4pm on friday"
      ]
    },
    {
      "automerge": true,
      "automergeType": "branch",
      "groupName": "renovate",
      "matchPackageNames": [
        "renovatebot/renovate"
      ],
      "schedule": [
        "after 4pm on friday"
      ]
    },
    {
      "groupName": "tdarr",
      "matchPackageNames": [
        "/^ghcr\\.io\\/haveagitgat\\/tdarr.*/"
      ]
    },
    {
      "groupName": "marinatedconcrete Unifi Network Application Kustomize Component",
      "groupSlug": "marinatedconcrete-kustomize-unifi-network-application",
      "matchCurrentValue": "kustomize-unifi-network-application@**",
      "matchPackageNames": ["marinatedconcrete/config"]
    }
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 6,
  "separateMinorPatch": true
}
